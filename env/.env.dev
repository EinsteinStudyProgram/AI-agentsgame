# ============================================================
# Django 基础配置
# ============================================================
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production-abcdef123456
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,*

# ============================================================
# PostgreSQL 数据库配置（含 pgvector）
# ============================================================
DB_NAME=ai_game
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# DeepSeek API 配置
# ============================================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ============================================================
# 模型路由 - 模型名称映射
# ============================================================
DEEPSEEK_MODEL_PRO=deepseek-chat
DEEPSEEK_MODEL_FLASH=deepseek-chat

# ============================================================
# Embedding 模型
# ============================================================
EMBEDDING_MODEL=text-embedding-ada-002

# ============================================================
# Redis 配置
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# 记忆系统配置
# ============================================================
MEMORY_RETRIEVAL_COUNT=10
MEMORY_IMPORTANCE_DECAY_HOURS=24
MEMORY_RECENCY_WEIGHT=0.3
MEMORY_IMPORTANCE_WEIGHT=0.3
MEMORY_RELEVANCE_WEIGHT=0.4
